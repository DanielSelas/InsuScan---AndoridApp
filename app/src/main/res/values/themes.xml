<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.InsuScan" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary colors (main brand color - medical blue) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <!-- Secondary colors (health green) -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="colorSecondaryContainer">@color/secondary_light</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>

        <!-- Error colors (medical critical) -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/text_on_primary</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/background_secondary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Divider color -->
        <item name="colorOutline">@color/divider</item>

    </style>

    <style name="Theme.InsuScan" parent="Base.Theme.InsuScan" />

    <style name="Widget.InsuScan.Chip.RefObject" parent="Widget.Material3.Chip.Filter">
        <!-- Background: transparent (unselected, like btn_gallery) / primary fill (selected, like btn_capture) -->
        <item name="chipBackgroundColor">@color/chip_ref_bg</item>
        <!-- Text: primary blue (unselected) / white (selected) -->
        <item name="android:textColor">@color/chip_ref_text</item>
        <item name="android:textSize">12sp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="chipStartPadding">10dp</item>
        <item name="chipEndPadding">10dp</item>
        <item name="chipCornerRadius">20dp</item>
        <!-- Stroke: primary blue border when unselected (like btn_gallery outline) -->
        <item name="chipStrokeWidth">1.5dp</item>
        <item name="chipStrokeColor">@color/primary</item>
        <item name="chipIconVisible">false</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipMinTouchTargetSize">0dp</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>


</resources>