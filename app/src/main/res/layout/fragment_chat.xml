<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <include
        android:id="@+id/top_bar"
        layout="@layout/view_top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/chat_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_medium"
            android:paddingEnd="@dimen/spacing_medium"
            android:paddingTop="@dimen/spacing_medium"
            android:paddingBottom="120dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_assistant"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/inter"
                android:textFontWeight="600"
                android:letterSpacing="0.08"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="@dimen/spacing_xs"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/corner_radius_card"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingStart="@dimen/spacing_large"
                    android:paddingEnd="@dimen/spacing_large"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        app:cardCornerRadius="36dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/background">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/insu_icon"
                            android:scaleType="centerCrop"
                            android:padding="2dp"/>

                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tv_chat_coming_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/chat_coming_title"
                        android:textSize="@dimen/text_h3"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="700"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:layout_marginTop="18dp" />

                    <TextView
                        android:id="@+id/tv_chat_coming_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/chat_coming_subtitle"
                        android:textSize="@dimen/text_body2"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginTop="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/spacing_large">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="@dimen/spacing_small"
                            android:paddingBottom="@dimen/spacing_small">

                            <TextView
                                android:layout_width="24dp"
                                android:layout_height="wrap_content"
                                android:text="•"
                                android:textSize="22sp"
                                android:textColor="@color/primary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/chat_feature_scan_insights"
                                android:textSize="@dimen/text_body2"
                                android:fontFamily="@font/inter"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:layout_marginStart="@dimen/spacing_large"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="@dimen/spacing_small"
                            android:paddingBottom="@dimen/spacing_small">

                            <TextView
                                android:layout_width="24dp"
                                android:layout_height="wrap_content"
                                android:text="•"
                                android:textSize="22sp"
                                android:textColor="@color/primary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tailored_dietary_recommendations"
                                android:textSize="@dimen/text_body2"
                                android:fontFamily="@font/inter"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:layout_marginStart="@dimen/spacing_large"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="@dimen/spacing_small"
                            android:paddingBottom="@dimen/spacing_small">

                            <TextView
                                android:layout_width="24dp"
                                android:layout_height="wrap_content"
                                android:text="•"
                                android:textSize="22sp"
                                android:textColor="@color/primary"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/chat_feature_smart_assistance"
                                android:textSize="@dimen/text_body2"
                                android:fontFamily="@font/inter"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_chat_coming_soon"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:text="@string/chat_coming_soon_button"
                        android:textSize="@dimen/text_body2"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="600"
                        android:textAllCaps="false"
                        android:textColor="@color/text_secondary"
                        android:enabled="false"
                        android:backgroundTint="@color/background"
                        app:cornerRadius="14dp"
                        style="@style/Widget.Material3.Button" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>