<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_large">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/summary_padding_horizontal"
            android:paddingEnd="@dimen/summary_padding_horizontal"
            android:paddingTop="@dimen/summary_padding_horizontal"
            android:paddingBottom="@dimen/spacing_small">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_home_greeting_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_home_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_h1_large"
                    android:fontFamily="@font/inter"
                    android:textFontWeight="700"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="-0.02" />

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_home_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar" />

        </LinearLayout>

        <!-- Glucose Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/summary_padding_horizontal"
            android:layout_marginTop="@dimen/padding_input_horizontal"
            app:cardCornerRadius="@dimen/corner_radius_card"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_medium">

                <com.example.insuscan.home.GlucoseGaugeView
                    android:id="@+id/gauge_glucose"
                    android:layout_width="80dp"
                    android:layout_height="80dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/spacing_medium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/summary_current_glucose"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="500"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/tv_glucose_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="@dimen/glucose_display_size"
                            android:fontFamily="@font/inter"
                            android:textFontWeight="700"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/unit_mgdl"
                            android:layout_marginStart="@dimen/spacing_xs"
                            android:textSize="@dimen/text_caption"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="@dimen/spacing_xs" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_glucose_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="In range"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="500"
                        android:textColor="@color/secondary"
                        android:layout_marginTop="@dimen/spacing_xs" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Daily Intake Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/summary_padding_horizontal"
            android:layout_marginTop="@dimen/padding_input_horizontal"
            app:cardCornerRadius="@dimen/corner_radius_card"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_today"
                            android:textSize="@dimen/text_caption"
                            android:fontFamily="@font/inter"
                            android:textFontWeight="500"
                            android:letterSpacing="0.1"
                            android:textAllCaps="true"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_daily_intake"
                            android:textSize="@dimen/text_body1"
                            android:fontFamily="@font/inter"
                            android:textFontWeight="600"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_meals_logged"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 meals logged"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/spacing_medium">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <TextView
                                android:id="@+id/tv_total_carbs"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="@dimen/insulin_dose_size"
                                android:fontFamily="@font/inter"
                                android:textFontWeight="700"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unit_grams"
                                android:layout_marginStart="2dp"
                                android:textSize="@dimen/text_body2"
                                android:fontFamily="@font/inter"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="2dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_carbs_label"
                            android:textSize="@dimen/text_caption"
                            android:fontFamily="@font/inter"
                            android:textFontWeight="500"
                            android:letterSpacing="0.1"
                            android:textAllCaps="true"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="@dimen/spacing_xs" />

                        <View
                            android:layout_width="40dp"
                            android:layout_height="3dp"
                            android:background="@color/primary"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <TextView
                                android:id="@+id/tv_total_insulin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="@dimen/insulin_dose_size"
                                android:fontFamily="@font/inter"
                                android:textFontWeight="700"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unit_units"
                                android:layout_marginStart="2dp"
                                android:textSize="@dimen/text_body2"
                                android:fontFamily="@font/inter"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="2dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_insulin_label"
                            android:textSize="@dimen/text_caption"
                            android:fontFamily="@font/inter"
                            android:textFontWeight="500"
                            android:letterSpacing="0.1"
                            android:textAllCaps="true"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="@dimen/spacing_xs" />

                        <View
                            android:layout_width="40dp"
                            android:layout_height="3dp"
                            android:background="@color/status_warning"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Scan CTA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="@dimen/summary_padding_horizontal"
            android:layout_marginTop="@dimen/spacing_medium">

            <Button
                android:id="@+id/btn_start_scan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/home_scan_meal_button"
                android:textSize="@dimen/text_body1"
                android:fontFamily="@font/inter"
                android:textFontWeight="500"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_nav_scan"
                app:iconGravity="textStart"
                app:iconTint="@color/white"
                app:iconPadding="8dp" />

            <Button
                android:id="@+id/btn_open_chat"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="@dimen/spacing_small"
                android:text="@string/home_ask_assistant_button"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/inter"
                android:textFontWeight="500"
                android:textAllCaps="false"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@android:color/transparent"
                app:icon="@drawable/ic_nav_chat"
                app:iconGravity="textStart"
                app:iconTint="@color/text_secondary"
                app:iconPadding="6dp"
                style="@style/Widget.Material3.Button.TextButton" />

        </LinearLayout>

        <!-- Insulin Plan Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="@dimen/summary_padding_horizontal"
            android:layout_marginTop="@dimen/summary_padding_horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/padding_input_horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_insulin_plan_section"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="@font/inter"
                    android:textFontWeight="500"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/tv_manage_plans"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_manage_plans"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="@font/inter"
                    android:textFontWeight="500"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/corner_radius_card"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/spacing_medium"
                    android:paddingEnd="@dimen/spacing_medium"
                    android:paddingTop="@dimen/spacing_xs"
                    android:paddingBottom="@dimen/spacing_xs">

                    <LinearLayout
                        android:id="@+id/row_default_plan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="?attr/selectableItemBackground">

                        <RadioButton
                            android:id="@+id/rb_default_plan"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:checked="true"
                            android:clickable="false"
                            android:button="@null"
                            android:background="@drawable/bg_radio_button" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/padding_input_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_plan_default"
                                android:textSize="@dimen/text_body2"
                                android:fontFamily="@font/inter"
                                android:textFontWeight="500"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_plan_profile_values"
                                android:textSize="@dimen/text_caption"
                                android:fontFamily="@font/inter"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tv_default_plan_details"
                            android:textSize="11.5sp"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/divider" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_plans"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>