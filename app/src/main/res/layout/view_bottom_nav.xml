<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="@color/white"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:elevation="8dp">

    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView
            android:id="@+id/icon_home"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_home"/>
        <TextView
            android:id="@+id/label_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textSize="10sp"
            android:fontFamily="@font/inter"
            android:layout_marginTop="3dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_history"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView
            android:id="@+id/icon_history"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_history"/>
        <TextView
            android:id="@+id/label_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="History"
            android:textSize="10sp"
            android:fontFamily="@font/inter"
            android:layout_marginTop="3dp"/>
    </LinearLayout>

    <!-- Scan FAB -->
    <LinearLayout
        android:id="@+id/nav_scan"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="?attr/selectableItemBackgroundBorderless">
        <LinearLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_scan_fab"
            android:layout_marginTop="-20dp"
            android:elevation="6dp">
            <ImageView
                android:id="@+id/icon_scan"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_scan"
                android:tint="@color/white"/>
            <TextView
                android:id="@+id/label_scan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan"
                android:textSize="10sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/white"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_chat"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView
            android:id="@+id/icon_chat"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_chat"/>
        <TextView
            android:id="@+id/label_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assist"
            android:textSize="10sp"
            android:fontFamily="@font/inter"
            android:layout_marginTop="3dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView
            android:id="@+id/icon_profile"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_profile"/>
        <TextView
            android:id="@+id/label_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You"
            android:textSize="10sp"
            android:fontFamily="@font/inter"
            android:layout_marginTop="3dp"/>
    </LinearLayout>

</LinearLayout>