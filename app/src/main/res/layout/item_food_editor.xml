<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_small"
    app:cardCornerRadius="@dimen/corner_radius_card"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <!-- Header row: name + undo + delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_food_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:text="Cherry Tomatoes"
                android:textSize="@dimen/text_body1"
                android:fontFamily="@font/inter"
                android:textFontWeight="600"
                android:textColor="@color/text_primary"
                android:maxLines="2"
                android:ellipsize="end" />

            <ImageButton
                android:id="@+id/btn_undo_item"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Reset item to original"
                android:layout_marginEnd="@dimen/spacing_xs"
                app:tint="@color/text_secondary"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_delete_item"
                app:tint="@color/status_error" />

        </LinearLayout>

        <!-- Weight chip + carbs info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_weight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="340g"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/inter"
                android:textFontWeight="500"
                android:textColor="@color/primary"
                android:background="@drawable/chip_primary_light"
                android:paddingHorizontal="@dimen/spacing_small"
                android:paddingVertical="3dp" />

            <TextView
                android:id="@+id/tv_carbs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="7g carbs (2g/100g)"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="@dimen/spacing_small" />

            <TextView
                android:id="@+id/tv_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/loading_searching_data"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/inter"
                android:textColor="@color/status_warning"
                android:layout_marginStart="@dimen/spacing_small"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Weight adjustment controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_minus"
                android:layout_width="@dimen/spacing_xl"
                android:layout_height="@dimen/spacing_xl"
                android:src="@drawable/ic_minus"
                android:background="@drawable/btn_circle_outline"
                android:contentDescription="@string/content_desc_decrease_weight" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_weight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="@dimen/spacing_small"
                android:valueFrom="10"
                android:valueTo="500"
                android:stepSize="5"
                app:trackColorActive="@color/primary"
                app:trackColorInactive="@color/divider"
                app:thumbColor="@color/primary" />

            <ImageButton
                android:id="@+id/btn_plus"
                android:layout_width="@dimen/spacing_xl"
                android:layout_height="@dimen/spacing_xl"
                android:src="@android:drawable/ic_input_add"
                android:background="@drawable/btn_circle_outline"
                android:contentDescription="@string/content_desc_increase_weight" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>