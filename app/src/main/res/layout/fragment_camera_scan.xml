<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/layout_step_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/view_step_dot_1"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/primary" />

        <View
            android:layout_width="24dp"
            android:layout_height="2dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="@color/text_disabled" />

        <View
            android:id="@+id/view_step_dot_2"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/text_disabled" />

    </LinearLayout>

    <android.opengl.GLSurfaceView
        android:id="@+id/hidden_ar_surface_view"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0.0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layout_step_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttons_container" />

    <LinearLayout
        android:id="@+id/layout_top_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_medium"
        android:paddingEnd="@dimen/spacing_medium"
        android:paddingTop="@dimen/spacing_small"
        android:paddingBottom="@dimen/spacing_small"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="@id/camera_preview"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview">

        <LinearLayout
            android:id="@+id/layout_ar_indicator"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/spacing_small"
            android:paddingEnd="@dimen/spacing_small">

            <View
                android:id="@+id/view_ar_indicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_circle"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_ar_explanation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginStart="8dp"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:background="@drawable/bg_status_pill"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btn_flash"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_flash"
            android:background="@drawable/bg_icon_overlay"
            android:contentDescription="Toggle flash"
            android:scaleType="centerInside"
            android:padding="9dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/chip_group_ref_object"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:padding="4dp"
        android:background="@drawable/chips_container"
        android:elevation="6dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview">

        <include layout="@layout/layout_reference_chips" />

    </LinearLayout>

    <TextView
        android:id="@+id/btn_ref_toggle"
        android:layout_width="@dimen/icon_large"
        android:layout_height="@dimen/icon_large"
        android:text="💉"
        android:background="@drawable/chips_background"
        android:textSize="18sp"
        android:elevation="8dp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:contentDescription="Selected reference object"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview" />

    <View
        android:id="@+id/view_plate_target_zone"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/dashed_border_oval"
        android:alpha="0.45"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview"
        app:layout_constraintTop_toTopOf="@id/camera_preview"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview" />

    <View
        android:id="@+id/view_target_zone"
        android:layout_width="50dp"
        android:layout_height="140dp"
        android:background="@drawable/dashed_border_rect"
        android:alpha="0.35"
        android:layout_marginStart="6dp"
        app:layout_constraintStart_toEndOf="@id/view_plate_target_zone"
        app:layout_constraintTop_toTopOf="@id/view_plate_target_zone"
        app:layout_constraintBottom_toBottomOf="@id/view_plate_target_zone" />

    <TextView
        android:id="@+id/tv_coach_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/scan_coach_too_dark"
        android:textColor="@color/text_on_primary"
        android:textSize="13sp"
        android:background="@drawable/bg_status_pill"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginEnd="@dimen/spacing_large"
        android:visibility="gone"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview" />

    <ImageView
        android:id="@+id/iv_captured_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/layout_step_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttons_container" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/buttons_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:paddingTop="0dp"
        android:paddingBottom="@dimen/spacing_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/row_glucose_ref"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:paddingStart="@dimen/spacing_large"
            android:paddingEnd="@dimen/spacing_large"
            app:layout_constraintTop_toTopOf="parent">

            <Button
                android:id="@+id/btn_reference_object"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="4dp"
                android:minWidth="130dp"
                android:text="No ref. object"
                android:textAllCaps="false"
                android:textSize="@dimen/text_caption" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_gallery"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="@dimen/spacing_xl"
            android:layout_marginBottom="8dp"
            app:layout_constraintVertical_bias="1.0"
            android:alpha="0.65"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_gallery"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/row_glucose_ref" />

        <Button
            android:id="@+id/btn_capture"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_capture_button_ring"
            android:elevation="12dp"
            android:text=""
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/row_glucose_ref"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="1.0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageButton
            android:id="@+id/btn_manual_entry"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="@dimen/spacing_xl"
            android:layout_marginBottom="8dp"
            app:layout_constraintVertical_bias="1.0"
            android:alpha="0.65"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Manual entry"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_edit"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/row_glucose_ref" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/ar_guidance_overlay"
        layout="@layout/layout_ar_guidance"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_side_photo_prompt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_small"
        android:visibility="gone"
        android:elevation="16dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/surface"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/buttons_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large">

            <TextView
                android:id="@+id/tv_side_card_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📐 Step 2: Side View"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_side_card_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tilt your phone sideways to show the depth of the plate. This helps us estimate volume more accurately."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="@dimen/spacing_large" />

            <Button
                android:id="@+id/btn_side_photo_ready"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="I'm Ready — Take Side Photo"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/button_primary"
                android:layout_marginBottom="@dimen/spacing_small" />

            <TextView
                android:id="@+id/tv_side_card_skip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Skip — continue with lower accuracy"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textAlignment="center"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_analyzing_meal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/loading_image_container"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/bg_rounded_blue_light"
            android:layout_marginBottom="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_loading_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed">

            <ImageView
                android:id="@+id/iv_loading_animation"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:src="@drawable/duck_camera" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_loading_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyzing your meal"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#0D1B2A"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/loading_image_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_loading_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This usually takes 5–8 seconds."
            android:textSize="16sp"
            android:textColor="#6C757D"
            android:layout_marginBottom="48dp"
            app:layout_constraintTop_toBottomOf="@id/tv_loading_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/loading_steps_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tv_loading_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                <ImageView android:id="@+id/step1_icon" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_step_inactive" />
                <TextView android:id="@+id/step1_text" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Processing image" android:textSize="16sp" android:textColor="#6C757D" android:layout_marginStart="16dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                <ImageView android:id="@+id/step2_icon" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_step_inactive" />
                <TextView android:id="@+id/step2_text" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Detecting food" android:textSize="16sp" android:textColor="#6C757D" android:layout_marginStart="16dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                <ImageView android:id="@+id/step3_icon" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_step_inactive" />
                <TextView android:id="@+id/step3_text" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Measuring portion" android:textSize="16sp" android:textColor="#6C757D" android:layout_marginStart="16dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                <ImageView android:id="@+id/step4_icon" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_step_inactive" />
                <TextView android:id="@+id/step4_text" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Calculating dose" android:textSize="16sp" android:textColor="#6C757D" android:layout_marginStart="16dp" />
            </LinearLayout>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/layout_loading_reference_notice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/warning_bg"
            app:layout_constraintTop_toBottomOf="@id/loading_steps_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="top">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠"
                    android:textSize="16sp"
                    android:textColor="@color/warning"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="1dp" />

                <TextView
                    android:id="@+id/tv_loading_reference_notice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12.5sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/warning"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/layout_glucose_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/card_background"
            android:elevation="16dp"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/et_glucose_level"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="Blood glucose (mg/dL)"
                android:inputType="number"
                android:textSize="15sp"
                android:textAlignment="center"
                android:background="@drawable/edit_text_background"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_submit_scan"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Show Results"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/button_primary" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_dark"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>