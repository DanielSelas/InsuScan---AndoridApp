<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <TextView
        android:id="@+id/tv_scan_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/scan_instruction_frame"
        android:textSize="@dimen/text_body2"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="@dimen/spacing_small"
        android:layout_marginStart="@dimen/spacing_large"
        android:layout_marginEnd="@dimen/spacing_large"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layout_step_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_scan_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/view_step_dot_1"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/primary" />

        <View
            android:layout_width="24dp"
            android:layout_height="2dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="@color/text_disabled" />

        <View
            android:id="@+id/view_step_dot_2"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/text_disabled" />

    </LinearLayout>

    <!-- Hidden GLSurfaceView strictly to maintain ARCore GL context in the background -->
    <android.opengl.GLSurfaceView
        android:id="@+id/hidden_ar_surface_view"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:alpha="0.0"
        app:layout_constraintTop_toTopOf="@id/camera_preview"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview" />

    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:layout_marginTop="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_medium"
        app:layout_constraintTop_toBottomOf="@id/layout_step_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttons_container" />

    <LinearLayout
        android:id="@+id/layout_ar_indicator"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_medium"
        android:paddingEnd="@dimen/spacing_medium"
        android:elevation="10dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="@id/camera_preview"
        app:layout_constraintStart_toStartOf="@id/camera_preview">

        <View
            android:id="@+id/view_ar_indicator"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/bg_circle"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_ar_explanation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginStart="8dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:background="@drawable/bg_status_pill"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <View
        android:id="@+id/view_target_zone"
        android:layout_width="@dimen/spacing_xl"
        android:layout_height="@dimen/meal_image_height"
        android:background="@drawable/dashed_border_rect"
        android:alpha="0.3"
        android:layout_marginEnd="@dimen/spacing_xl"
        app:layout_constraintEnd_toEndOf="@id/camera_preview"
        app:layout_constraintTop_toTopOf="@id/camera_preview"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview" />

    <View
        android:id="@+id/view_plate_target_zone"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/dashed_border_oval"
        android:alpha="0.55"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview"
        app:layout_constraintTop_toTopOf="@id/camera_preview"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview" />

    <TextView
        android:id="@+id/tv_coach_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/scan_coach_too_dark"
        android:textColor="@color/text_on_primary"
        android:background="@drawable/bg_status_pill"
        android:paddingStart="@dimen/padding_input_horizontal"
        android:paddingEnd="@dimen/padding_input_horizontal"
        android:paddingTop="@dimen/spacing_small"
        android:paddingBottom="@dimen/spacing_small"
        android:layout_marginTop="@dimen/spacing_large"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/camera_preview"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview" />

    <LinearLayout
        android:id="@+id/chip_group_ref_object"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:padding="4dp"
        android:background="@drawable/chips_container"
        android:elevation="6dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview">

        <include layout="@layout/layout_reference_chips" />

    </LinearLayout>

    <TextView
        android:id="@+id/btn_ref_toggle"
        android:layout_width="@dimen/icon_large"
        android:layout_height="@dimen/icon_large"
        android:text="💉"
        android:background="@drawable/chips_background"
        android:textSize="18sp"
        android:elevation="8dp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:contentDescription="Selected reference object"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview"
        app:layout_constraintStart_toStartOf="@id/camera_preview"
        app:layout_constraintEnd_toEndOf="@id/camera_preview" />

    <ImageView
        android:id="@+id/iv_captured_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:layout_marginTop="@dimen/spacing_medium"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/tv_scan_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttons_container" />

    <LinearLayout
        android:id="@+id/layout_quality_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_small"
        android:paddingEnd="@dimen/spacing_small"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:layout_marginTop="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:elevation="4dp"
        app:layout_constraintBottom_toTopOf="@id/buttons_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_quality_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/scan_validating_preview"
            android:textAlignment="center"
            android:background="@drawable/bg_status_pill"
            android:textSize="@dimen/text_body1"
            android:textColor="@color/text_on_primary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:visibility="gone"
            android:paddingBottom="6dp"
            android:layout_marginStart="@dimen/padding_input_horizontal"
            android:layout_marginEnd="0dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/buttons_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_small"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: Capture + Gallery -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_small">

            <Button
                android:id="@+id/btn_capture"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="85"
                android:text="Capture"
                android:textSize="@dimen/text_button"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/button_primary"
                android:layout_marginEnd="2dp" />

            <ImageButton
                android:id="@+id/btn_gallery"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="15"
                android:src="@android:drawable/ic_menu_gallery"
                android:scaleType="centerInside"
                android:background="@drawable/button_primary"
                android:contentDescription="Gallery" />
        </LinearLayout>

        <!-- Row 2: Glucose input + Reference Object -->
        <LinearLayout
            android:id="@+id/row_glucose_ref"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/et_glucose_level"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="Blood glucose (mg/dL)"
                android:inputType="number"
                android:textSize="@dimen/text_body2"
                android:textAlignment="center"
                android:background="@drawable/edit_text_background"
                android:layout_marginEnd="@dimen/spacing_small" />

            <Button
                android:id="@+id/btn_reference_object"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="No ref. object"
                android:textSize="@dimen/text_caption"
                android:textAllCaps="false"
                android:minWidth="130dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

    </LinearLayout>

    <include
        android:id="@+id/ar_guidance_overlay"
        layout="@layout/layout_ar_guidance"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_side_photo_prompt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:layout_marginBottom="@dimen/spacing_small"
        android:visibility="gone"
        android:elevation="16dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/surface"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/buttons_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large">

            <TextView
                android:id="@+id/tv_side_card_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📐 Step 2: Side View"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_side_card_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tilt your phone sideways to show the depth of the plate. This helps us estimate volume more accurately."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="@dimen/spacing_large" />

            <Button
                android:id="@+id/btn_side_photo_ready"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="I'm Ready — Take Side Photo"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/button_primary"
                android:layout_marginBottom="@dimen/spacing_small" />

            <TextView
                android:id="@+id/tv_side_card_skip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Skip — continue with lower accuracy"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textAlignment="center"
                android:paddingTop="8dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_dark"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/tv_loading_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_analyzing"
            android:textColor="@color/text_on_primary"
            android:textSize="@dimen/text_body1"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/loading_text_margin_top" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>