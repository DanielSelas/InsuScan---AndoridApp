<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:id="@+id/chip_ref_syringe"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="10dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/ref_chip_unselected_bg"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="💉"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/chip_icon_bg"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Syringe"
            android:textSize="12sp"
            android:textColor="@color/primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chip_ref_fork"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="10dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/ref_chip_unselected_bg"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="🍴"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/chip_icon_bg"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fork"
            android:textSize="12sp"
            android:textColor="@color/primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chip_ref_card"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="10dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/ref_chip_unselected_bg"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="💳"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/chip_icon_bg"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Card"
            android:textSize="12sp"
            android:textColor="@color/primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chip_ref_none"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="10dp"
        android:background="@drawable/ref_chip_unselected_bg"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="❌"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/chip_icon_bg"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="None"
            android:textSize="12sp"
            android:textColor="@color/primary" />
    </LinearLayout>

</merge>