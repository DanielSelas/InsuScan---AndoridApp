<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_large"
    android:background="@color/surface">

    <TextView
        android:id="@+id/tv_edit_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_body1"
        android:fontFamily="@font/inter"
        android:textFontWeight="600"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="@dimen/spacing_medium" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_edit_value"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/edit_text_background"
            android:paddingStart="@dimen/padding_input_horizontal"
            android:paddingEnd="@dimen/padding_input_horizontal"
            android:textSize="@dimen/text_body1"
            android:fontFamily="@font/inter"
            android:textColor="@color/text_primary"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tv_edit_suffix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_caption"
            android:fontFamily="@font/inter"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="@dimen/spacing_small"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/summary_padding_horizontal">

        <Button
            android:id="@+id/btn_edit_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textAllCaps="false"
            android:fontFamily="@font/inter"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/background"
            android:layout_marginEnd="@dimen/spacing_small"
            app:cornerRadius="@dimen/corner_radius_button"
            style="@style/Widget.Material3.Button" />

        <Button
            android:id="@+id/btn_edit_save"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Save"
            android:textAllCaps="false"
            android:fontFamily="@font/inter"
            android:textColor="@color/text_on_primary"
            android:backgroundTint="@color/primary"
            android:layout_marginStart="@dimen/spacing_small"
            app:cornerRadius="@dimen/corner_radius_button"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

</LinearLayout>