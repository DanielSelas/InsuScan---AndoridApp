<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main row -->
        <LinearLayout
            android:id="@+id/layout_meal_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <!-- Meal time icon -->
            <FrameLayout
                android:id="@+id/fl_meal_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_meal_icon"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tv_meal_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="20sp" />

            </FrameLayout>

            <!-- Name + time + carbs -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_meal_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14.5sp"
                    android:fontFamily="@font/inter"
                    android:textFontWeight="600"
                    android:textColor="@color/text_primary"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/tv_meal_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_secondary" />

                    <View
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tv_meal_carbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/primary"
                        android:textFontWeight="500" />

                </LinearLayout>

            </LinearLayout>

            <!-- Dose badge -->
            <TextView
                android:id="@+id/tv_dose_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textFontWeight="700"
                android:textColor="@color/white"
                android:background="@drawable/bg_dose_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginEnd="10dp" />

            <!-- Chevron -->
            <TextView
                android:id="@+id/tv_expand_chevron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="20sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Expanded content -->
        <LinearLayout
            android:id="@+id/layout_expanded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginBottom="10dp" />

            <!-- Glucose + Activity + Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GLUCOSE"
                        android:textSize="9sp"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="500"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tv_glucose"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="500"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PLAN"
                        android:textSize="9sp"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="500"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tv_plan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="500"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATUS"
                        android:textSize="9sp"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="500"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="500"
                        android:textColor="@color/secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Food items -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FOOD ITEMS"
                android:textSize="9sp"
                android:fontFamily="@font/inter"
                android:textFontWeight="500"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_food_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="10dp" />

            <!-- Dose calculation -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOSE CALCULATION"
                        android:textSize="9sp"
                        android:fontFamily="@font/inter"
                        android:textFontWeight="500"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Carb dose"
                            android:textSize="12.5sp"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tv_carb_dose"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12.5sp"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_correction_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Correction"
                            android:textSize="12.5sp"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/text_secondary" />
                        <TextView
                            android:id="@+id/tv_correction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12.5sp"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/status_warning" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/divider"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Final dose"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter"
                            android:textFontWeight="600"
                            android:textColor="@color/text_primary" />
                        <TextView
                            android:id="@+id/tv_final_dose"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter"
                            android:textFontWeight="700"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>