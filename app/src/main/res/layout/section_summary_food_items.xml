<?xml version="1.0" encoding="utf-8"?>
<!-- Detected items section — extracted from fragment_summary.xml.
     Wrapper LinearLayout groups: section label + food items card + add/edit buttons. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Detected items -->
    <TextView
        android:id="@+id/tv_detected_items_label"
        style="@style/TextStyle.SectionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/summary_detected_items"
        android:layout_marginTop="@dimen/summary_section_margin_top"
        android:layout_marginBottom="@dimen/spacing_small" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/corner_radius_card"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:id="@+id/layout_meal_items_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_card"
            android:paddingEnd="@dimen/padding_card"
            android:paddingTop="@dimen/spacing_xs"
            android:paddingBottom="@dimen/spacing_xs" />

    </androidx.cardview.widget.CardView>

    <!-- Add / Edit buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/padding_input_horizontal">

        <Button
            android:id="@+id/btn_add_food"
            style="@style/ButtonStyle.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/summary_button_height"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/summary_add_item"
            android:textSize="@dimen/text_caption"
            app:cornerRadius="10dp" />

        <Button
            android:id="@+id/btn_edit_meal"
            style="@style/ButtonStyle.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/summary_button_height"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/summary_edit_meal"
            android:textSize="@dimen/text_caption"
            app:cornerRadius="10dp" />

    </LinearLayout>

</LinearLayout>
